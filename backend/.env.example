# Environment Configuration
# Copy this file to .env and fill in the values

# Environment: development, staging, or production
ENVIRONMENT=development
DEBUG=true

# Supabase Configuration (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API Settings
API_TITLE=Plant Management API
API_VERSION=1.0.0
API_PREFIX=/api/v1

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Supabase Client Timeouts (seconds) — lower values fail fast on network issues
SUPABASE_POSTGREST_TIMEOUT=10
SUPABASE_STORAGE_TIMEOUT=20
SUPABASE_FUNCTION_TIMEOUT=10

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_UPLOAD=10

# File Upload Settings
MAX_UPLOAD_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
LOG_TO_DATABASE=true
LOG_SAMPLE_RATE=1.0

# Background Jobs
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY_SECONDS=5

# Metrics
METRICS_ENABLED=true
METRICS_FLUSH_INTERVAL_SECONDS=60

# AI Configuration for Remarks Parsing
# OpenAI API Key (PRIMARY - recommended)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Google Gemini API Key (FALLBACK - kept for future use if OpenAI quota exceeded)
# Get your key from: https://makersuite.google.com/app/apikey
# Currently disabled but code is preserved for future use
GEMINI_API_KEY=your-gemini-api-key
